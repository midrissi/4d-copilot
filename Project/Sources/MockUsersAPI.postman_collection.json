{
	"info": {
		"name": "👥 Mock Users API",
		"description": "🚀 A mock REST API for managing users, built with 4D / Qodly.\n\n📦 **Base URL:** `http://localhost:8080`\n\n🗄️ Users are stored **in-memory** via `Storage` — data resets on server restart.\n\n---\n\n### 📋 User object\n```json\n{\n  \"id\":    \"1\",\n  \"name\":  \"Alice\",\n  \"email\": \"alice@example.com\"\n}\n```\n\n### ⚡ Quick start\n1. Start your 4D / Qodly web server\n2. Make sure `HTTPHandlers.json` is loaded (restart if needed)\n3. Fire away! 🎉",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost",
			"type": "string",
			"description": "🌐 Base URL of your 4D / Qodly web server"
		},
		{
			"key": "userId",
			"value": "1",
			"type": "string",
			"description": "🔑 ID of the target user"
		}
	],
	"item": [
		{
			"name": "📋 List all users",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/users",
					"host": ["{{baseUrl}}"],
					"path": ["api", "users"]
				},
				"description": "📋 **Retrieve all users** stored in memory.\n\n✅ Returns an empty array `[]` if no users exist yet."
			},
			"response": [
				{
					"name": "✅ 200 — Users found",
					"status": "OK",
					"code": 200,
					"header": [{ "key": "Content-Type", "value": "application/json" }],
					"body": "[\n  { \"id\": \"1\", \"name\": \"Alice\", \"email\": \"alice@example.com\" },\n  { \"id\": \"2\", \"name\": \"Bob\",   \"email\": \"bob@example.com\" }\n]"
				},
				{
					"name": "✅ 200 — Empty list",
					"status": "OK",
					"code": 200,
					"header": [{ "key": "Content-Type", "value": "application/json" }],
					"body": "[]"
				}
			]
		},
		{
			"name": "🔍 Get user by ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/users/{{userId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "users", "{{userId}}"]
				},
				"description": "🔍 **Retrieve a single user** by their ID.\n\n🔑 Set the `userId` variable (or replace in the URL) with the target user's ID."
			},
			"response": [
				{
					"name": "✅ 200 — User found",
					"status": "OK",
					"code": 200,
					"header": [{ "key": "Content-Type", "value": "application/json" }],
					"body": "{ \"id\": \"1\", \"name\": \"Alice\", \"email\": \"alice@example.com\" }"
				},
				{
					"name": "❌ 404 — User not found",
					"status": "Not Found",
					"code": 404,
					"header": [{ "key": "Content-Type", "value": "application/json" }],
					"body": "{ \"error\": \"User not found\" }"
				}
			]
		},
		{
			"name": "➕ Create user",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\":  \"Alice\",\n  \"email\": \"alice@example.com\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "{{baseUrl}}/api/users",
					"host": ["{{baseUrl}}"],
					"path": ["api", "users"]
				},
				"description": "➕ **Create a new user**.\n\n### 📝 Request body\n| Field   | Type   | Required | Description         |\n|---------|--------|----------|---------------------|\n| `name`  | string | ✅ yes   | Full name of user   |\n| `email` | string | ✅ yes   | Email address       |\n\n🆔 The `id` is auto-assigned by the server."
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"var json = pm.response.json();",
							"if (json.success && json.result && json.result.id) {",
							"    pm.collectionVariables.set('userId', json.result.id);",
							"}"
						]
					}
				}
			],
			"response": [
				{
					"name": "✅ 201 — User created",
					"status": "Created",
					"code": 201,
					"header": [{ "key": "Content-Type", "value": "application/json" }],
					"body": "{ \"id\": \"1\", \"name\": \"Alice\", \"email\": \"alice@example.com\" }"
				}
			]
		},
		{
			"name": "✏️ Update user",
			"request": {
				"method": "PUT",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\":  \"Alice Smith\",\n  \"email\": \"alice.smith@example.com\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "{{baseUrl}}/api/users/{{userId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "users", "{{userId}}"]
				},
				"description": "✏️ **Update an existing user** by their ID.\n\n### 📝 Request body (all fields optional)\n| Field   | Type   | Required | Description               |\n|---------|--------|----------|---------------------------|\n| `name`  | string | ⬜ no    | New full name             |\n| `email` | string | ⬜ no    | New email address         |\n\n💡 Only provided fields are updated — missing fields are left unchanged."
			},
			"response": [
				{
					"name": "✅ 200 — User updated",
					"status": "OK",
					"code": 200,
					"header": [{ "key": "Content-Type", "value": "application/json" }],
					"body": "{ \"id\": \"1\", \"name\": \"Alice Smith\", \"email\": \"alice.smith@example.com\" }"
				},
				{
					"name": "❌ 404 — User not found",
					"status": "Not Found",
					"code": 404,
					"header": [{ "key": "Content-Type", "value": "application/json" }],
					"body": "{ \"error\": \"User not found\" }"
				}
			]
		},
		{
			"name": "🗑️ Delete user",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/users/{{userId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "users", "{{userId}}"]
				},
				"description": "🗑️ **Permanently delete a user** by their ID.\n\n⚠️ This action is irreversible. The user is removed from memory immediately."
			},
			"response": [
				{
					"name": "✅ 200 — User deleted",
					"status": "OK",
					"code": 200,
					"header": [{ "key": "Content-Type", "value": "application/json" }],
					"body": "{ \"message\": \"User deleted\" }"
				},
				{
					"name": "❌ 404 — User not found",
					"status": "Not Found",
					"code": 404,
					"header": [{ "key": "Content-Type", "value": "application/json" }],
					"body": "{ \"error\": \"User not found\" }"
				}
			]
		}
	]
}
